# Discord Bot Token - https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application Client ID (Bot sayfasından al)
CLIENT_ID=your_client_id_here

# Guild ID - Slash komutları test etmek için (Discord'da sunucuya sağ tıkla → ID kopyala)
# Production'da bu satırı sil veya boş bırak (global komutlar için)
GUILD_ID=your_guild_id_here

# yt-dlp Proxy - YouTube bot korumasını atlatmak için (opsiyonel)
# Format: http://kullanici:sifre@ip:port
YTDLP_PROXY=http://username:password@ip:port

# YouTube Data API v3 Key - Arama için (opsiyonel ama ÖNERİLİR, sunucu IP sorununu bypass eder)
# Nasıl alınır: https://console.cloud.google.com → API & Services → YouTube Data API v3
# Ücretsiz kota: günlük 10.000 birim (1 arama = 100 birim → 100 arama/gün ücretsiz)
YOUTUBE_API_KEY=

# YouTube Cookies - Bot koruması için (opsiyonel, base64 encoded cookies.txt)
# Nasıl alınır: tarayıcıya "Get cookies.txt LOCALLY" eklentisini kur, youtube.com'da dışa aktar
# base64'e çevir: base64 -w 0 cookies.txt
YOUTUBE_COOKIES_BASE64=
